<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<BorderPane prefWidth="1000" prefHeight="600"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.tasktraker.controller.AdminController">

    <top>
        <HBox style="-fx-padding: 10;">
            <Label fx:id="adminInfoLabel" style="-fx-font-size: 16;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="300" style="-fx-padding: 10;">
            <Label text="Projects" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <ListView fx:id="projectList"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label text="Create Project" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

            <TextField fx:id="projectNameField" promptText="Project name"/>
            <TextArea fx:id="projectDescriptionField" promptText="Description" prefRowCount="3"/>

            <Button text="Create Project" onAction="#handleCreateProject"/>

            <Separator/>

            <Label text="Create Task" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <TextField fx:id="taskTitleField" promptText="Task title"/>
            <TextArea fx:id="taskDescriptionField" promptText="Task description" prefRowCount="4"/>
            <ComboBox fx:id="assigneeComboBox" promptText="Assignee" maxWidth="Infinity"/>
            <ComboBox fx:id="priorityComboBox" promptText="Priority" maxWidth="Infinity"/>
            <Button text="Create Task" onAction="#handleCreateTask"/>
        </VBox>
    </center>

    <right>
        <VBox spacing="10" prefWidth="300" style="-fx-padding: 10;">
            <Label text="Assign User" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

            <ComboBox fx:id="userComboBox" promptText="Select user" maxWidth="Infinity"/>
            <Button text="Assign to Project" onAction="#handleAssignUser"/>

            <Separator/>

            <Label text="Project Members" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <ListView fx:id="projectUsersList"/>
        </VBox>
    </right>

</BorderPane>
