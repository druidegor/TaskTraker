<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.tasktraker.controller.RegisterController">

    <children>

        <!-- 🔹 ФОН -->
        <VBox alignment="CENTER" spacing="20"
              style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298);"
              prefWidth="1000" prefHeight="600">

            <!-- 🔹 КАРТОЧКА -->
            <VBox spacing="15" alignment="CENTER"
                  style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);"
                  maxWidth="400">

                <!-- 🔹 Заголовок -->
                <Label text="Create Account"
                       style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                <Label text="Join TaskTracker"
                       style="-fx-text-fill: #7f8c8d;"/>

                <!-- 🔹 Поля -->
                <TextField fx:id="nameField"
                           promptText="Full Name"
                           style="-fx-background-radius: 8; -fx-padding: 8;"/>

                <TextField fx:id="emailField"
                           promptText="Email"
                           style="-fx-background-radius: 8; -fx-padding: 8;"/>

                <PasswordField fx:id="passwordField"
                               promptText="Password"
                               style="-fx-background-radius: 8; -fx-padding: 8;"/>

                <PasswordField fx:id="confirmPasswordField"
                               promptText="Confirm Password"
                               style="-fx-background-radius: 8; -fx-padding: 8;"/>

                <!-- 🔹 Роль -->
                <ComboBox fx:id="roleComboBox" promptText="Select Role" maxWidth="Infinity"/>

                <!-- 🔹 Кнопка -->
                <Button text="Register"
                        fx:id="registerButton"
                        maxWidth="Infinity"
                        style="-fx-background-color: #2a5298; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10;"/>

                <!-- 🔹 Ошибка -->
                <Label fx:id="errorLabel"
                       textFill="red"
                       visible="false"/>

                <!-- 🔹 Переход -->
                <Hyperlink text="Already have an account? Login"
                           fx:id="loginLink"/>

            </VBox>

        </VBox>

    </children>

</StackPane>