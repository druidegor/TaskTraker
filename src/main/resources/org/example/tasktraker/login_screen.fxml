<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="org.example.tasktraker.controller.LoginController">

    <children>

        <VBox alignment="CENTER" prefHeight="600" prefWidth="1000" spacing="20" style="-fx-background-color: linear-gradient(to bottom, #1e3c72, #2a5298);">

            <VBox alignment="CENTER" maxWidth="350" prefHeight="293.0" prefWidth="350.0" spacing="15" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 20, 0, 0, 5);">

                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="TaskTracker" />

                <Label style="-fx-text-fill: #7f8c8d;" text="Login to your account" />

                <TextField fx:id="emailField" promptText="Email" style="-fx-background-radius: 8; -fx-padding: 8;" />

                <PasswordField fx:id="passwordField" promptText="Password" style="-fx-background-radius: 8; -fx-padding: 8;" />

                <Button fx:id="loginButton" maxWidth="Infinity" style="-fx-background-color: #2a5298; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10;" text="Login" />

                <Label fx:id="errorLabel" textFill="red" visible="false" />
            <Hyperlink fx:id="registerLink" prefHeight="23.0" prefWidth="195.0" text="Don't have an account? Sing Up" textAlignment="CENTER" />

            </VBox>

        </VBox>

    </children>

</StackPane>
